{
  "moderation": {
    "title": "Az üzeneted törölve lett!",
    "description": [
      "Flag: **%flag%**",
      "A törlés oka: **%description%**"
    ],
    "color": [255, 127, 0],
    "footer": "Ranked.hu",
    "keep_for": 5,
    "alert": {
      "title": "Moderáció",
      "description": [
        "**%username% (%id%)** felhasználó be lett flagelve a következő indok miatt: **%reason%**",
        "Üzenet: **%message%**",
        "Időpont: %time%",
        "Csatorna: %path%"
      ],
      "color": [255, 127, 0],
      "footer": "Ranked.hu",
      "actions": {
        "user_left": "A felhasználó nincs bent a szerveren!",
        "mute": {
          "text": "Némítás",
          "style": "PRIMARY",
          "done": "Felhasználó %user% **(%id%)** le lett némítva!",
          "fail": "A felhasználó már le van némítva!"
        },
        "kick": {
          "text": "Kick",
          "style": "DANGER",
          "done": "Felhasználó %user% **(%id%)** ki lett kickelve!"
        },
        "ban": {
          "text": "Ban",
          "style": "DANGER",
          "done": "Felhasználó %user% **(%id%)** ki lett bannolva!"
        }
      },
      "timeout": {
        "after": 3,
        "punishment": 5,
        "title": "Le lettél némítva!",
        "description": [
          "Le lettél némítva túl sok nem megengedett üzenet küldése miatt!",
          "A némításod lejár: %time%"
        ],
        "color": [255, 127, 0],
        "footer": "Ranked.hu"
      }
    }
  },
  "welcome": {
    "embed": {
      "title": "%emoji% | `Csatlakozás`",
      "description": [
        "Üdvözlünk a szerveren, %user%!",
        "Kérlek olvasd el a szabályzatot a %channel% csatornában!"
      ],
      "color": [255, 127, 0],
      "footer": "Ranked.hu"
    }
  },
  "test-result": {
    "embed": {
      "title": "Teszt Eredmény",
      "description": [
        "%tester% **%tier%** tiert adott %player% (**%username%**) játékosnak!",
        "**Játékmód**: %gamemode%"
      ],
      "color": [255, 127, 0],
      "footer": "Ranked.hu"
    }
  },
  "commands": {
    "ticket": {
      "name": "ticket-nyitas",
      "description": "Ticket nyitása",
      "prefix": "ticket-",
      "archived-prefix": "archived-",
      "created": "Ticket elkészítve: %channel%",
      "topic": [
        "⮚ Készítette: %username%",
        "⮚ Id: %id%"
      ],
      "fail": "Már van ticketed!",
      "error": "Nem sikerült a ticketet elkészíteni!",
      "embed": {
        "title": "Írd le a problémádat!",
        "description": [
          "%user%, köszönjük, hogy nyitott ticketet!",
          "Csapattagunk hamarosan válaszol, addig kérem írja le a problémáját/kérelmét a folyamat felgyorsítása érdekében!"
        ],
        "ping": "@here",
        "color": [255, 127, 0],
        "footer": "Ranked.hu - %id%",
        "actions": {
          "user_left": "A felhasználó nincs bent a szerveren!",
          "permission": "Nincs ehhez jogod!",
          "close": {
            "text": "\uD83D\uDD12 Lezárás",
            "style": "DANGER",
            "done": "A ticket sikeresen lezárva!",
            "timeout": 3,
            "fail": "Nem sikerült a ticketet törölni!"
          },
          "archive": {
            "text": "\uD83D\uDCC1 Archiválás",
            "style": "PRIMARY",
            "timeout": 1,
            "done": "A ticket sikeresen archiválva %user% által!",
            "fail": "Nem sikerült a ticketet archiválni!"
          }
        }
      }
    },
    "ticket-panel": {
      "name": "ticket-panel",
      "description": "Ticket panel kiírása",
      "done": "A ticket panel kész!",
      "permission": "Nincs jogod ehhez!",
      "embed": {
        "title": "Hibajegy nyitása",
        "description": [
          "Kattints a \uD83D\uDCE8 gombra, hogy nyiss egy hibajegyet!"
        ],
        "color": [255, 127, 0],
        "footer": "Ranked.hu",
        "actions": {
          "open": {
            "text": "\uD83D\uDCE8",
            "style": "SUCCESS"
          }
        }
      }
    },
    "profile": {
      "name": "profile",
      "description": "Játékos profiljának megnyitása",
      "fail": "Ez a felhasználó nincsen regisztrálva a szerveren!",
      "missing": "Állíts be egy játékost!",
      "options": [
        {
          "type": "USER",
          "name": "player",
          "description": "A játékos Discordja",
          "required": false
        },
        {
          "type": "STRING",
          "name": "minecraft_name",
          "description": "A játékos neve",
          "required": false
        }
      ],
      "embed": {
        "title": "**%player%** profilja",
        "description": [
          "Discord: **%discord%**",
          "Helyezés: **#%position%**",
          "Pontok: **%score%**"
        ],
        "color": [255, 127, 0],
        "footer": "Ranked.hu"
      }
    }
  }
}