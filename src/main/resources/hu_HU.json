{
  "moderation": {
    "title": "Az üzeneted törölve lett!",
    "description": [
      "Flag: **%flag%**",
      "A törlés oka: **%description%**"
    ],
    "color": [255, 127, 0],
    "footer": "Ranked.hu",
    "keep_for": 5,
    "alert": {
      "title": "Moderáció",
      "description": [
        "**%username% (%id%)** felhasználó be lett flagelve a következő indok miatt: **%reason%**",
        "Üzenet: **%message%**",
        "Időpont: %time%",
        "Csatorna: %path%"
      ],
      "color": [255, 127, 0],
      "footer": "Ranked.hu",
      "actions": {
        "user_left": "A felhasználó nincs bent a szerveren!",
        "mute": {
          "text": "Némítás",
          "style": "PRIMARY",
          "done": "Felhasználó %user% **(%id%)** le lett némítva!",
          "fail": "A felhasználó már le van némítva!"
        },
        "kick": {
          "text": "Kick",
          "style": "DANGER",
          "done": "Felhasználó %user% **(%id%)** ki lett kickelve!"
        },
        "ban": {
          "text": "Ban",
          "style": "DANGER",
          "done": "Felhasználó %user% **(%id%)** ki lett bannolva!"
        }
      },
      "timeout": {
        "after": 3,
        "punishment": 5,
        "title": "Le lettél némítva!",
        "description": [
          "Le lettél némítva túl sok nem megengedett üzenet küldése miatt!",
          "A némításod lejár: %time%"
        ],
        "color": [255, 127, 0],
        "footer": "Ranked.hu"
      }
    }
  },
  "commands": {
    "ticket": {
      "name": "ticket-nyitas",
      "description": "Ticket nyitása",
      "prefix": "ticket-",
      "created": "Ticket elkészítve: %channel%",
      "topic": [
        "⮚ Készítette: %username%",
        "⮚ Id: %id%"
      ],
      "fail": "Már van ticketed!",
      "embed": {
        "title": "Írd le a problémádat!",
        "description": [
          "%user%, köszönjük, hogy nyitott ticketet!",
          "Csapattagunk hamarosan válaszol, addig kérem írja le a problémáját/kérelmét a folyamat felgyorsítása érdekében!"
        ],
        "ping": "@here",
        "color": [255, 127, 0],
        "footer": "Ranked.hu - %id%",
        "actions": {
          "user_left": "A felhasználó nincs bent a szerveren!",
          "permission": "Nincs ehez jogod!",
          "close": {
            "text": "\uD83D\uDD12 Lezárás",
            "style": "DANGER",
            "done": "A ticket sikeresen lezárva!",
            "timeout": 3,
            "fail": "Nem sikerült a ticketet törölni!"
          },
          "archive": {
            "text": "\uD83D\uDCC1 Archiválás",
            "style": "PRIMARY",
            "done": "A ticket sikeresen archiválva %user% által!",
            "fail": "Nem sikerült a ticketet archiválni!"
          }
        }
      }
    }
  }
}